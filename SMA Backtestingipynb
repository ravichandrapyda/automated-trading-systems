   "source": [
    "def test_startegy(SMA):\n",
    "    data =df.copy()\n",
    "    data[\"returns\"] = np.log(data.price.div(data.price.shift(1)))\n",
    "    data[\"SMA_Small\"] = data.price.rolling(int(SMA[0])).mean()\n",
    "    data[\"SMA_Long\"] = data.price.rolling(int(SMA[1])).mean()\n",
    "    data.dropna(inplace=True)\n",
    "\n",
    "    data[\"position\"] = np.where(data[\"SMA_Small\"]>data[\"SMA_Long\"],1,-1)\n",
    "    data[\"Startegy\"] = data.position.shift(1)*data[\"returns\"]\n",
    "\n",
    "    return np.exp(data[\"Startegy\"].sum())"
   ]
  },
